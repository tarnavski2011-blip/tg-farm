generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AnimalType {
  CHICKEN
  SHEEP
  COW
}

model User {
  id              Int      @id @default(autoincrement())
  telegramId      BigInt   @unique

  coins           Int      @default(0)
  diamonds        Int      @default(0)
  points          Int      @default(0)

  level Int @default(1)
xp    Int @default(0)

  feedUntil       DateTime?
  feedActivatedAt DateTime?

  lastTapAt       DateTime? @default(now())

  boostUntil      DateTime?
  vipUntil        DateTime?

  // ✅ автозбір
  autoCollectUntil DateTime?

  lastDailyAt     DateTime?
  dailyStreak     Int       @default(0)

  warehouseLevel  Int       @default(1)
  labLevel        Int       @default(1)

  payments Payment[]

  createdAt       DateTime  @default(now())
  lastSeenAt DateTime @default(now())
  labMultiplier Int @default(1)

  referrals     Referral[] @relation("Referrer")
referredBy    Referral?  @relation("Invited")
lastWheelSpinAt DateTime?
dailyQuestClaims DailyQuestClaim[]



  animals         Animal[]
  storage         Storage?
  achievementClaims AchievementClaim[]
}

model Storage {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  eggs      Int      @default(0)
  wool      Int      @default(0)
  milk      Int      @default(0)
  capacity Int @default(1000)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Animal {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      AnimalType
  level     Int       @default(1)
  lastClaim DateTime  @default(now())
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model AchievementClaim {
  id              Int      @id @default(autoincrement())
  userId          Int
  code            String
  claimed         Boolean  @default(false)
  claimedAt       DateTime?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId])
}

model Referral {
  id         Int      @id @default(autoincrement())
  referrerId Int
  invitedId  Int      @unique
  createdAt  DateTime @default(now())

  referrer   User @relation("Referrer", fields: [referrerId], references: [id])
  invited    User @relation("Invited", fields: [invitedId], references: [id])
}

model DailyQuestClaim {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  claimDate String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code, claimDate])
  @@index([userId, claimDate])
}

model Payment {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  productCode             String
  payload                 String   @unique
  currency                String
  amount                  Int
  status                  String   @default("pending")
  telegramPaymentChargeId String?  @unique
  providerPaymentChargeId String?
  metadataJson            String?
  createdAt               DateTime @default(now())
  paidAt                  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([productCode])
}
